# Skopiuj ten plik do `.env` i uzupełnij swoimi kluczami API.
# cp .env.example .env

# Klucz do API OpenAI (model językowy + agent).
OPENAI_API_KEY=sk-...

# Klucz do SerpAPI (wyszukiwanie Google). https://serpapi.com/
SERPAPI_API_KEY=...

# --- Opcjonalne (mają sensowne wartości domyślne w config.py) ---
# Model językowy używany przez chatbota / agenta.
# LLM_MODEL=gpt-4o-mini
# Model CLIP z HuggingFace Hub.
# CLIP_MODEL=openai/clip-vit-base-patch32
# Model embeddingów (sentence-transformers).
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
